{
  "builds": [
    {
      "src": "miniapp_api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/user/(.*)", "dest": "miniapp_api.py" },
    { "src": "/rates", "dest": "miniapp_api.py" },
    { "src": "/exchange", "dest": "miniapp_api.py" },
    { "src": "/", "dest": "/webapp.html" }
  ]
}
